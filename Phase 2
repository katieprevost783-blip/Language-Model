import random

print("AI: Hi, I'm here to listen. You can talk to me anytime. (type 'exit' to leave)\n")

# --- Memory ---
memory = {
    "last_emotion": None,
    "last_input": None
}

# --- Response banks ---
sad_responses = [
    "It sounds like you're feeling really down. That can be heavy to carry. I'm really glad you told me.",
    "I hear that you're feeling sad. You don't have to go through that alone.",
]

stress_responses = [
    "It sounds like you're feeling stressed. That kind of pressure can build up fast.",
    "I can tell you're overwhelmed. That’s a lot to carry right now.",
]

motivation_responses = [
    "It sounds like you're struggling with motivation. That can happen when you're drained.",
    "I hear that you're feeling unmotivated. You're not lazy — you're probably overwhelmed or tired.",
]

general_responses = [
    "I'm here with you. Want to talk more about it?",
    "That sounds important. I’m listening.",
    "Tell me more about what’s been going on.",
]

# --- Follow-up questions (NEW) ---
follow_ups = [
    "Do you want to tell me what led to that feeling?",
    "Has this been happening for a while or just recently?",
    "What part of it feels the hardest right now?",
    "Do you want advice or just someone to listen?"
]

# --- Emotion detection ---
def detect_emotion(user_input):
    user_input = user_input.lower()
    
    if any(word in user_input for word in ["sad", "upset", "hurt", "depressed"]):
        return "sad"
    elif any(word in user_input for word in ["stressed", "overwhelmed", "anxious", "pressure"]):
        return "stress"
    elif any(word in user_input for word in ["lazy", "unmotivated", "tired", "can't start"]):
        return "motivation"
    else:
        return "general"

# --- Reflection ---
def reflect(user_input):
    return f"It sounds like you're feeling this way: \"{user_input}\""

# --- Response generator ---
def get_response(emotion):
    if emotion == "sad":
        return random.choice(sad_responses)
    elif emotion == "stress":
        return random.choice(stress_responses)
    elif emotion == "motivation":
        return random.choice(motivation_responses)
    else:
        return random.choice(general_responses)

# --- Chat loop ---
while True:
    user = input("You: ")

    if user.lower() == "exit":
        print("AI: I'm really glad you talked with me. Take care of yourself.")
        break

    emotion = detect_emotion(user)

    memory["last_emotion"] = emotion
    memory["last_input"] = user

    reflection = reflect(user)
    response = get_response(emotion)
    follow_up = random.choice(follow_ups)

    print(f"\nAI: {reflection}")
    print(response)
    print(follow_up + "\n")